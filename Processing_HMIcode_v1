// ==== ОБРАБОТКА ИНТЕРФЕЙСА =====
// Список портов
void com(int n) {
  portName = Serial.list()[n];  // Запоминаем выбранный порт в portName
}

// Кнопка открытия порта
void openPort() {
  if (portName != null && serial == null) {     // Если выбран порт и сейчас он закрыт,
    serial = new Serial(this, portName, speed); // открываем portName.
    if (isStarted == false){                    // Переключение видимости элементов интерфейса при запуске
      cp5.getController("startControl").show();
    }
    else {
      showControls();
    }
  }
}

// Кнопка закрытия порт
void closePort() {
  if (serial != null) { // Если порт открыт,
    serial.stop();      // закрываем portName,
    serial = null;      // serial выключен
    hideControls();
    cp5.getController("startControl").hide();
  }
}

// Отображение управления и переход механизма в начальное положение
void startControl(){
  showControls();
  isStarted = true;
  command = 0;
  data = ",0";
  sendPacket(keyMessage, command, data);
  cp5.getController("startControl").hide();
}

// Скрытие управления и переход механизма в конечное положение с выключением
void turnOff(){
  hideControls();
  isStarted = false;
  command = 2;
  data = ",0";
  sendPacket(keyMessage, command, data);
  cp5.getController("startControl").show();
}

//Отправка значений углов сервоприводов
void sendAngles() {
  for (int i = 0; i < SERVONUM; i++) {
    angles[i] = int((cp5.get(Textfield.class, "servo" + str(i)).getText()));
    if (angles[i] > anglesMax[i] || angles[i] < anglesMin[i]) {               // Проверка на выход прописанных значений углов за допустимые пределы и подготовка предупреждения
      angleWarning = angleWarning + " " + str(i+1);
    }
    else {                                                                    // При корректно введённых значениях подготовка сообщения с параметрами управления
      data = data + "," + str(angles[i]);
    }
  }
  if (angleWarning != "") {                                                   // При наличии введённых значений вне допустимых пределов, показывается сообщение с предупреждением
    anglesWarning.setText("Введены неверные значения" + "\n" + "углов для сервоприводов " + angleWarning + '!');
    angleWarning = "";
    data = "";
  }
  else {                                                                      // При отсутствии введённых значений вне допустимых пределов, отправка сообщения с параметрами на Arduino
    keyMessage = "$";
    command = 1;
    sendPacket(keyMessage, command, data);
    anglesWarning.setText("");
  }
}

// Реализация команд
void moveForward() {
  angles[0] = 90;
  angles[1] = 180;
  angles[2] = 90;
  angles[3] = 90;
  for (int i = 0; i < SERVONUM; i++) {
    data = data + "," + str(angles[i]);
  }
  keyMessage = "$";
  command = 1;
  sendPacket(keyMessage, command, data);
}

void moveDown() {
  angles[0] = 90;
  angles[1] = 90;
