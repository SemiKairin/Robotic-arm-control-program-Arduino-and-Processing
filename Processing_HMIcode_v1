// ==== ВСПОМОГАТЕЛЬНЫЕ ФУНКЦИИ =====
// Скрытие управления
void hideControls() {
  cp5.getTab("default").hide();
  cp5.getTab("commandsTab").hide();
  cp5.getController("turnOff").hide();
  anglesWarning.setText("");
}

// Появление управления
void showControls() {
  cp5.getTab("default").show();
  cp5.getTab("commandsTab").show();
  cp5.getController("turnOff").show();
}

// При закрытии приложения срабатывает переход механизма в конечное положение с выключением
void exit() {
  if(isStarted) turnOff();
  closePort();
  super.exit();
}
