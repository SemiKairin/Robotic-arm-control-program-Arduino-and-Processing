// Функция для отправки сообщения на Ардуино
void sendPacket(String keyMessageS, int commandS, String dataS) {
  if (serial != null) serial.write(keyMessageS + str(commandS) + dataS + ';');
  // отправит "keyMessage"+"command,data;"
  data = "";
}




